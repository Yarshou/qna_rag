# Secret template — DO NOT commit real values.
#
# In production use one of:
#   - kubectl create secret generic qna-rag-secrets --from-literal=...
#   - Sealed Secrets (https://github.com/bitnami-labs/sealed-secrets)
#   - External Secrets Operator backed by Vault / AWS SSM / GCP Secret Manager
#
# Only ONE provider block is needed (Azure OR generic).
#
apiVersion: v1
kind: Secret
metadata:
  name: qna-rag-secrets
  namespace: default
type: Opaque
stringData:
  # ── Option A: Azure OpenAI ─────────────────────────────────────────────────
  azure-openai-api-key: "replace-me"
  # AZURE_OPENAI_ENDPOINT and AZURE_OPENAI_DEPLOYMENT are not sensitive;
  # they can live in the Deployment env block as plain values.

  # ── Option B: Generic OpenAI-compatible provider ───────────────────────────
  # openai-api-key: "replace-me"
