apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: qna-rag
  namespace: default
  annotations:
    # Set the ingress class that exists in your cluster, for example nginx.
    kubernetes.io/ingress.class: nginx
    # Uncomment when cert-manager is installed and you want managed TLS.
    # cert-manager.io/cluster-issuer: letsencrypt-prod
spec:
  # Uncomment to enable TLS termination at ingress level.
  # tls:
  #   - hosts:
  #       - qna-rag.example.com
  #     secretName: qna-rag-tls
  rules:
    - host: qna-rag.example.com
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: qna-rag
                port:
                  number: 80
