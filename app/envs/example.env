#
# Copy this file to app/envs/.env before running the service.
#
# The client auto-detects the provider from which variable group is set.
# Set ONE of the two blocks below — Azure takes precedence when both are present.
#
DEBUG=true
APP_PORT=8000
APP_WORKERS=1
DATABASE_PATH=app/data/qna_rag.sqlite3
KNOWLEDGE_DIR=knowledge

 MAX_INPUT_LENGTH=4000
 MAX_OUTPUT_LENGTH=8000
 MAX_TOOL_ROUND_TRIPS=4
 KNOWLEDGE_MAX_FILE_SIZE_MB=10

# ── Option A: Azure OpenAI ────────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=replace-me
AZURE_OPENAI_ENDPOINT=https://example-resource.openai.azure.com/
OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4.1

# ── Option B: Generic OpenAI-compatible provider ──────────────────────────────
# Works with OpenRouter (https://openrouter.ai/api/v1),
# EPAM DIAL, local Ollama (http://localhost:11434/v1), and any other
# provider that implements the OpenAI chat-completions API.
#
# OPENAI_API_KEY=replace-me
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=meta-llama/llama-3-8b-instruct
